VITE_API_BASE_URL=http://localhost:4200
VITE_API_BASIC_AUTH_USER=staging-user
VITE_API_BASIC_AUTH_PASSWORD=staging-password

# Subscription UI: `1` = dev (relax paywall / show dev banner); `0` = product-like gates.
# Alias: `VITE_DEV_MODE`. Unset defaults to `1` under `npm run dev` and `0` for `npm run build`.
# DEV_MODE=1

VITE_USE_API_PROXY=1
# API origin only — no path suffix. Wrong: `https://api.example.com/api` (Nest HTTP routes are `/auth`, `/users`, …).
VITE_DEV_PROXY_TARGET=http://localhost:4200

VITE_LOG_API_ERRORS=1
VITE_SKIP_SUBSCRIPTION_ENFORCEMENT=true

VITE_SITE_URL=https://explys.com
VITE_API_TOKEN=



VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...


VITE_SALES_CONTACT_EMAIL=sales@example.com
VITE_SALES_CONTACT_URL=https://example.com/contact
