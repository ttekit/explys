# API (see backend `.env` for `API_TOKEN` if you call production)
VITE_API_BASE_URL=http://localhost:4200
# Optional dev-only: proxy API through Vite (avoids CORS when remote `CORS_ORIGINS` omits localhost).
# VITE_USE_API_PROXY=1
# VITE_DEV_PROXY_TARGET=http://localhost:4200
# Log failed API responses in the browser console when not using `vite dev` (e.g. staging): `1` or `true`
# VITE_LOG_API_ERRORS=1
# Match backend `SKIP_SUBSCRIPTION_ENFORCEMENT` for builds where you are not using `vite dev`
# (e.g. preview against a remote API). Same values: true, 1, or yes (case-insensitive).
# Note: `npm run dev` already skips subscription gates and post-checkout payment confirmation UI.
# VITE_SKIP_SUBSCRIPTION_ENFORCEMENT=true
# Public site URL for canonical links and Open Graph (production, e.g. https://explys.com)
# VITE_SITE_URL=https://explys.com
# VITE_API_TOKEN=
# If the token contains `$` (e.g. Argon2), escape each as `\$` in this file or Vite will corrupt the value.

# Stripe publishable key (optional). Same value as backend STRIPE_PUBLISHABLE_KEY unless you rely on GET /billing/stripe-publishable-key instead.
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Optional: Teacher / Enterprise "Contact us" on pricing (mailto if URL not set)
# VITE_SALES_CONTACT_EMAIL=sales@example.com
# VITE_SALES_CONTACT_URL=https://example.com/contact
