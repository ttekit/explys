model Content {
  id           Int    @id @default(autoincrement())
  friendlyLink String @unique @map("friendly_link")
  name         String
  description  String

  videos ContentVideo[] // Связь для плейлиста

  ownerUserId Int?           @map("owner_user_id")
  ownerUser   User?          @relation("TeacherOwnedContent", fields: [ownerUserId], references: [id], onDelete: SetNull)
  visibility  String         @default("public")
  category    ContentMedia[]
  createAt    DateTime       @default(now()) @map("create_at")
  updateAt    DateTime       @updatedAt @map("update_at")

  @@index([ownerUserId], map: "contents_owner_user_id_idx")
  @@map("contents")
}

model ContentMedia {
  id               Int            @id @default(autoincrement())
  categoryId       Int            @map("category_id")
  category         Content        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  playlistPosition Int            @default(0) @map("playlist_position")
  createAt         DateTime       @default(now()) @map("create_at")
  updateAt         DateTime       @updatedAt @map("update_at")
  stats            ContentStats?
  ContentVideo     ContentVideo[]

  @@unique([categoryId, playlistPosition], map: "content_medias_category_id_playlist_position_key")
  @@map("content_medias")
}

model ContentStats {
  id             Int          @id @default(autoincrement())
  contentMediaId Int          @unique @map("content_media_id")
  contentMedia   ContentMedia @relation(fields: [contentMediaId], references: [id], onDelete: Cascade)

  usersWatched Int   @default(0) @map("users_watched")
  rating       Float @default(0)

  /// CEFR band tags from transcript analysis (e.g. A2, B1)
  systemTags           String[] @default([]) @map("system_tags")
  /// Theme / topic tags from transcript analysis
  userTags             String[] @default([]) @map("user_tags")
  /// 1–10 processing load estimate, or null if not inferred
  processingComplexity Int?     @map("processing_complexity")

  topics Topic[]

  @@map("content_stats")
}

model ContentVideo {
  id Int @id @default(autoincrement())

  // Зв'язок зі слотом (для статистики і категорій) - поле називається content
  contentId Int          @map("content_id")
  content   ContentMedia @relation(fields: [contentId], references: [id], onDelete: Cascade)

  // Зв'язок із серіалом (для плейлиста) - поле називається series
  seriesId Int?     @map("series_id")
  series   Content? @relation(fields: [seriesId], references: [id], onDelete: SetNull)

  playlistPosition Int     @default(0) @map("playlist_position")
  videoLink        String  @map("video_link")
  videoName        String  @map("video_name")
  videoDescription String? @map("video_description")
  episodeNumber    Int     @default(1)
  thumbnailUrl     String?

  videoCaption               VideoCaptions?
  postWatchSurveys           PostWatchSurvey[]
  watchSessions              WatchSession[]
  comprehensionTestAttempts  ComprehensionTestAttempt[]
  userComprehensionWeakSpots UserComprehensionWeakSpot[]

  @@unique([contentId, playlistPosition], map: "content_videos_content_id_playlist_position_key")
  @@map("content_videos")
}

/// Per-user misses on a clip; used to bias future quiz generation toward similar skills.
model UserComprehensionWeakSpot {
  id             Int          @id @default(autoincrement())
  userId         Int          @map("user_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentVideoId Int          @map("content_video_id")
  contentVideo   ContentVideo @relation(fields: [contentVideoId], references: [id], onDelete: Cascade)

  category    String @map("category")
  stemHash    String @map("stem_hash") @db.VarChar(64)
  stemSnippet String @map("stem_snippet") @db.VarChar(500)

  missCount    Int      @default(1) @map("miss_count")
  lastMissedAt DateTime @default(now()) @map("last_missed_at")

  @@unique([userId, contentVideoId, stemHash])
  @@index([userId, contentVideoId, lastMissedAt])
  @@map("user_comprehension_weak_spots")
}

/// Deduped per user/video/calendar day (UTC); updated on subsequent watch-complete same day.
model WatchSession {
  id             Int          @id @default(autoincrement())
  userId         Int          @map("user_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentVideoId Int          @map("content_video_id")
  contentVideo   ContentVideo @relation(fields: [contentVideoId], references: [id], onDelete: Cascade)
  /// Calendar date (UTC) for idempotent completion counting.
  completionDate DateTime     @map("completion_date") @db.Date
  startedAt      DateTime?    @map("started_at")
  endedAt        DateTime     @default(now()) @map("ended_at")
  secondsWatched Int          @default(0) @map("seconds_watched")
  completed      Boolean      @default(true)

  @@unique([userId, contentVideoId, completionDate])
  @@index([userId, contentVideoId, endedAt])
  @@index([endedAt])
  @@map("watch_sessions")
}

model ComprehensionTestAttempt {
  id             Int          @id @default(autoincrement())
  userId         Int          @map("user_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentVideoId Int          @map("content_video_id")
  contentVideo   ContentVideo @relation(fields: [contentVideoId], references: [id], onDelete: Cascade)
  correct        Int
  total          Int
  scorePct       Float        @map("score_pct")
  passed         Boolean
  details        Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, contentVideoId, createdAt])
  @@index([createdAt])
  @@map("comprehension_test_attempts")
}

model VideoCaptions {
  id             Int          @id @default(autoincrement())
  contentVideoId Int          @unique @map("content_video_id")
  contentVideo   ContentVideo @relation(fields: [contentVideoId], references: [id], onDelete: Cascade)

  subtitlesFileLink String   @map("subtitles_file_link")
  createAt          DateTime @default(now()) @map("create_at")
  updateAt          DateTime @updatedAt @map("update_at")

  @@map("video_captions")
}

/// Short comprehension / reflection survey shown after the learner finishes watching a video.
model PostWatchSurvey {
  id             Int          @id @default(autoincrement())
  contentVideoId Int          @map("content_video_id")
  contentVideo   ContentVideo @relation(fields: [contentVideoId], references: [id], onDelete: Cascade)
  userId         Int?         @map("user_id")
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  /// JSON array: { id, type, prompt, options? }[]
  questionsJson  Json         @map("questions_json")
  answersJson    Json?        @map("answers_json")
  createdAt      DateTime     @default(now()) @map("created_at")
  submittedAt    DateTime?    @map("submitted_at")

  @@index([contentVideoId, userId])
  @@map("post_watch_surveys")
}
