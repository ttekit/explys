generator client {
  provider = "prisma-client"
  output   = "../../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    Int           @id @default(autoincrement())
  name                  String
  email                 String        @unique
  password              String
  role                  UserRole      @default(REGULAR)
  hasCompletedPlacement Boolean       @default(false) @map("has_completed_placement")
  lastLogin             DateTime?
  createdAt             DateTime      @default(now()) @map("update_at")
  teacherId             Int?          @map("teacher_id")
  teacher               User?         @relation("UserTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  students              User[]        @relation("UserTeacher")
  settings              UserSettings?

  isVerified        Boolean    @default(false) @map("is_verified")
  isTwoFactorEnable Boolean    @default(false) @map("is_two_factor_enable")
  method            AuthMethod

  accounts Account[]

  statistic          UserStatistic?
  languageData       UserLanguageData[]
  additionalUserData AdditionalUserData?
  friends            UserFriend[]        @relation("UserFriends")
  friendOf           UserFriend[]        @relation("UserFriendsReverse")
  postWatchSurveys   PostWatchSurvey[]
  userVocabulary     UserVocabulary[]

  @@index([teacherId], map: "users_teacher_id_idx")
  @@map("users")
}

model Account {
  id Int @id @default(autoincrement())

  type     String
  provider String

  refreshToken String? @map("refresh_token")
  accessToken  String? @map("access_token")
  expiresAt    Int     @map("expires_at")

  user   User? @relation(fields: [userId], references: [id])
  userId Int   @map("user_id")
}

model Token {
  id Int @id @default(autoincrement())

  email     String    @unique
  token     String    @unique
  type      TokenType
  expiresIn DateTime  @map("expiresIn")

  @@map("tokens")
}

enum UserRole {
  REGULAR
  STUDENT
  TEACHER
  ADULT
  ADMIN
}

enum AuthMethod {
  CREDENTIALS
  GOOGLE
}

enum TokenType {
  VERIFICATION
  TWO_FACTOR
  PASSWORD_RESET
}

model AdditionalUserData {
  id                  Int      @id @default(autoincrement())
  userId              Int      @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nativeLanguage      String?
  knownLanguages      String[]
  knownLanguageLevels Json?
  job                 String?
  education           String?
  englishLevel        String?
  workField           String?
  hobbies             String[]
  interests           String[]

  teacherGrades        String?
  teacherTopics        String[]
  /// Roster of pupils as JSON, e.g. [{ "name", "surname" }] — matches DB JSONB
  studentNames         Json?
  studentGrade         String?
  studentProblemTopics String[]

  selectedTopics Topic[] @relation("SelectedTopics")
  favoriteGenres Genre[] @relation("FavoriteGenres")
  hatedGenres    Genre[] @relation("HatedGenres")

  @@map("additional_user_data")
}

model Genre {
  id          Int                  @id @default(autoincrement())
  name        String               @unique
  favoritedBy AdditionalUserData[] @relation("FavoriteGenres")
  hatedBy     AdditionalUserData[] @relation("HatedGenres")

  @@map("genres")
}

model Topic {
  id             Int                  @id @default(autoincrement())
  name           String
  categoryId     Int
  category       Category             @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  complexity     Float
  language       String
  tags           Tag[]
  contentStats   ContentStats[]
  selectedBy     AdditionalUserData[] @relation("SelectedTopics")
  languageData   UserLanguageData[]
  userVocabulary UserVocabulary[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@map("topics")
}

model Category {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  topics Topic[]

  @@map("categories")
}

model Tag {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  topics Topic[]

  @@map("tags")
}

model UserSettings {
  id                Int     @id @default(autoincrement())
  userId            Int     @unique
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentResolution String?
  playbackSpeed     Float?
  studyingLanguage  String?

  @@map("settings")
}

model UserStatistic {
  id                  Int       @id @default(autoincrement())
  userId              Int       @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  studyingProgress    Float?
  lastLesson          DateTime?
  isCurrentlyLearning Boolean   @default(false)
  learnedAmount       Int       @default(0)

  @@map("statistics")
}

model UserLanguageData {
  id               Int      @id @default(autoincrement())
  userId           Int
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topicId          Int
  topic            Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  score            Float
  confidence       Float    @default(0)
  coverage         Float    @default(0)
  algorithmVersion String   @default("v1")
  updatedAt        DateTime @updatedAt

  @@unique([userId, topicId])
  @@map("user_language_data")
}

model UserFriend {
  id                    Int      @id @default(autoincrement())
  userId                Int
  user                  User     @relation("UserFriends", fields: [userId], references: [id], onDelete: Cascade)
  friendId              Int
  friend                User     @relation("UserFriendsReverse", fields: [friendId], references: [id], onDelete: Cascade)
  friendshipCreatedDate DateTime @default(now())

  @@map("user_friends")
}

model UserVocabulary {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Study language (matches DB `language_code`)
  language  String   @map("language_code")
  term      String
  source    String   @default("topic_tags")
  topicId   Int?     @map("topic_id")
  topic     Topic?   @relation(fields: [topicId], references: [id], onDelete: SetNull)
  mastery   Float    @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([userId, language, term])
  @@index([userId, language])
  @@map("user_vocabulary")
}
