{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": false,
    "assets": [
      { "include": "generated/**/*", "watch": true },
      { "include": "placement-test/data/**/*", "watch": true }
    ]
  }
}