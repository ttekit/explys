# ----- PostgreSQL (Explys DB) -----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=exply
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Server
PORT=4200
NODE_ENV=development

# Public SPA origin (OAuth redirect after login, transactional email links, email-confirm redirect).
FRONTEND_URL=http://localhost:5173
# Public URL of this API (OAuth redirect_uri root). In production set explicitly (e.g. https://api.example.com).
# When unset in development, defaults to http://localhost:${PORT}.
# PUBLIC_API_URL=http://localhost:4200

# Browser origins allowed for CORS (comma-separated). When NODE_ENV=production this must be set.
# Include dev ports, production domains, and (optional) raw IP smoke tests, e.g.:
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://explys.com,https://www.explys.com,http://91.232.30.6,http://91.232.30.6:5173
# When unset in development, any origin is reflected (permissive for local testing).
#
# Max JSON / urlencoded body size for Nest (e.g. profile PATCH with large studying-plan JSON).
# If the browser reports "blocked by CORS" with status 413, nginx/Cloudflare may be rejecting the
# body before Nest — raise client_max_body_size (nginx) / proxy limits to match or exceed this.
# Example snippet: backend/nginx/explys-reverse-proxy.example.conf
HTTP_JSON_BODY_LIMIT=500mb

# JWT (required)
JWT_SECRET="change-me-jwt-secret"

# API integration token: required on EVERY request when NODE_ENV=production (header: x-api-token).
# In development, the global API token check is disabled.
# Must match frontend `VITE_API_TOKEN` for admin/dashboard API calls from the SPA.
API_TOKEN="change-me-shared-api-token-replace-me"

# Rate limiting (contents / uploads module)
UPLOAD_RATE_TTL=60
UPLOAD_RATE_LIMIT=10

# Max video upload size for POST/PATCH /contents (bytes). Default in code: 512 MiB if unset.
# Must stay ≤ nginx client_max_body_size. Was 100 MiB — raise here if you lowered nginx only.
# CONTENT_VIDEO_MAX_FILE_BYTES=536870912

# Subscription checks on protected API routes:
# - In NODE_ENV=development, enforcement is OFF by default (no Stripe needed locally).
# - Set SKIP_SUBSCRIPTION_ENFORCEMENT=false to force enforcement while developing.
# - In production, set SKIP_SUBSCRIPTION_ENFORCEMENT=true only if you intend to bypass (rare).
# Mirrors frontend: vite dev skips gates; VITE_SKIP_SUBSCRIPTION_ENFORCEMENT for preview builds.
# SKIP_SUBSCRIPTION_ENFORCEMENT=true

# Optional: restrict who may embed the comprehension test iframe (CSP frame-ancestors). Default: *
# Example (single origin): COMPREHENSION_TEST_FRAME_ANCESTORS="'self' https://app.example.com"
COMPREHENSION_TEST_FRAME_ANCESTORS=

# ----- Email (SMTP / Nest Mailer) -----
# When true (also 1 / yes): skip all outbound mail; register creates verified users;
# first login auto-verifies legacy unverified accounts. Use until SMTP/TLS is fixed.
# DISABLE_EMAIL=false
# MAIL_HOST=
# MAIL_PORT=587
# MAIL_LOGIN=
# MAIL_PASSWORD=
# MAIL_FROM=<no-reply@example.com>

# Gemini API
GEMINI_MODEL="gemini-3.1-flash-lite-preview"
GEMINI_API_KEY="your-gemini-api-key"

# Deepgram captions (Listen API). Flow: FFmpeg extracts 16 kHz mono PCM WAV locally, then Listen POST (`audio/wav`).
DEEPGRAM_API_KEY=
# Default model for WAV transcription: nova-3. Override only if Deepgram directs (e.g. nova-3-general).
# DEEPGRAM_TRANSCRIBE_MODEL=nova-3

# FFmpeg for caption pipeline (bundled `@ffmpeg-installer/ffmpeg` unless set).
# FFMPEG_PATH=

# AWS S3
AWS_REGION="eu-central-1"
AWS_S3_REGION="eu-central-1"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_S3_BUCKET_NAME="your-bucket-name"

# ----- Stripe (billing) -----
# Secret key — server only (never commit). Test: sk_test_..., live: sk_live_...
STRIPE_SECRET_KEY=
# Publishable key — safe in the browser. Test: pk_test_..., live: pk_live_...
# Also exposed via GET /billing/stripe-publishable-key (optional; SPA can use VITE_STRIPE_PUBLISHABLE_KEY instead).
STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret (whsec_...) from Stripe Dashboard or `stripe listen` for POST /billing/webhook.
# Enable events: checkout.session.completed, checkout.session.async_payment_succeeded,
# customer.subscription.created, customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=
# Subscription price IDs (recurring monthly prices in Stripe).
STRIPE_PRICE_ID_LIGHT=
STRIPE_PRICE_ID_SMART=
STRIPE_PRICE_ID_FAMILY=
# After Checkout Stripe redirects the browser here (SPA). Must match cancel URL host/port if local.
# Server appends session_id={CHECKOUT_SESSION_ID} & checkout=success. If SUCCESS points at /subscribe it is rewritten to /catalog on the cancel URL origin.
# Leave STRIPE_CHECKOUT_SUCCESS_URL empty to use {same origin as CANCEL_URL}/catalog
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:5173/catalog
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:5173/subscribe


# Dev: turn off all outbound email + confirmation (no SMTP). Remove in production.
DISABLE_EMAIL=true